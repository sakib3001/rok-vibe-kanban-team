# Copy to .env and fill in. NEVER commit .env (already covered by .gitignore).
# Generate secrets:
#   POSTGRES_PASSWORD     ->  openssl rand -base64 24 | tr -d '/+='
#   ELECTRIC_ROLE_PASSWORD->  openssl rand -base64 24 | tr -d '/+='
#   JWT_SECRET            ->  openssl rand -base64 32     (MUST be valid base64 decoding to >=32 bytes)

# ---- Public address -----------------------------------------------------------
PUBLIC_DOMAIN=vk.example.com        # the host developers point their client at
ACME_EMAIL=ops@example.com          # Let's Encrypt account email
# Use Caddyfile.local for localhost testing; keep Caddyfile for production.
CADDYFILE_PATH=Caddyfile

# ---- Database / secrets -------------------------------------------------------
POSTGRES_PASSWORD=change-me
ELECTRIC_ROLE_PASSWORD=change-me
JWT_SECRET=change-me-base64-32-bytes
# Optional override for local validation only; defaults to https://${PUBLIC_DOMAIN}.
SERVER_PUBLIC_BASE_URL=

# ---- Identity -----------------------------------------------------------------
# Restrict sign-in to your org domains (comma-separated). Empty = allow anyone.
ALLOWED_EMAIL_DOMAINS=rokomari.com

# Pick AT LEAST ONE OAuth provider. Callback URL to register with the provider:
#   https://${PUBLIC_DOMAIN}/v1/oauth/callback/github   (or /google, /zoho)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
# Dev-only fallback when OAuth app is not configured (Phase 0 only).
SELF_HOST_LOCAL_AUTH_EMAIL=
SELF_HOST_LOCAL_AUTH_PASSWORD=

# ---- Email (Phase 2: org invitations) -----------------------------------------
# Leave empty to skip invite emails and share invite links manually instead.
LOOPS_EMAIL_API_KEY=

# ---- Images / registry ---------------------------------------------------------
# DEFAULT: build locally from the patched source via ./build.sh (recommended;
# the built image includes the patched backend + remote-web frontend).
REMOTE_IMAGE=vibe-kanban-team-remote
IMAGE_TAG=local
ELECTRIC_TAG=1.3.3

# To use a prebuilt registry image instead of building, point these at it, e.g.:
#   REMOTE_IMAGE=ghcr.io/iamriajul/vibe-kanban-team-remote
#   IMAGE_TAG=0.1.44-20260617110518
# Override the source path for ./build.sh if your layout differs:
#   VK_DIR=../vibe-kanban

# ---- Issue-ingestion API (optional; docker compose --profile ingest) ----------
# Secret API key callers must send as `X-API-Key` (generate: openssl rand -hex 32)
INGEST_API_KEY=
# Service-account credentials (self-host local auth). This email MUST be a member
# of the team org that owns INGEST_PROJECT_ID. See ingest/README.md setup.
INGEST_SVC_EMAIL=issue-bot@rokomari.com
INGEST_SVC_PASSWORD=
# Target project UUID where issues are created.
INGEST_PROJECT_ID=
# Team org UUID — only needed to resolve `assignee` emails on POST.
INGEST_ORG_ID=
# Default status: by name substring (default "todo"), or pin an exact status UUID.
INGEST_STATUS_NAME=todo
INGEST_STATUS_ID=
# Base URL used to build issue links in the response (defaults to https://PUBLIC_DOMAIN).
INGEST_PUBLIC_URL=
