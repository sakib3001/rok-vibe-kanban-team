# Copy to .env and fill in. NEVER commit .env (already covered by .gitignore).
# Generate secrets:
#   POSTGRES_PASSWORD     ->  openssl rand -base64 24 | tr -d '/+='
#   ELECTRIC_ROLE_PASSWORD->  openssl rand -base64 24 | tr -d '/+='
#   JWT_SECRET            ->  openssl rand -base64 32     (MUST be valid base64 decoding to >=32 bytes)

# ---- Public address -----------------------------------------------------------
PUBLIC_DOMAIN=vk.example.com        # the host developers point their client at
ACME_EMAIL=ops@example.com          # Let's Encrypt account email
# Use Caddyfile.local for localhost testing; keep Caddyfile for production.
CADDYFILE_PATH=Caddyfile

# ---- Database / secrets -------------------------------------------------------
POSTGRES_PASSWORD=change-me
ELECTRIC_ROLE_PASSWORD=change-me
JWT_SECRET=change-me-base64-32-bytes
# Optional override for local validation only; defaults to https://${PUBLIC_DOMAIN}.
SERVER_PUBLIC_BASE_URL=

# ---- Identity -----------------------------------------------------------------
# Restrict sign-in to your org domains (comma-separated). Empty = allow anyone.
ALLOWED_EMAIL_DOMAINS=rokomari.com

# Pick AT LEAST ONE OAuth provider. Callback URL to register with the provider:
#   https://${PUBLIC_DOMAIN}/v1/oauth/github/callback   (or /google)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Dev-only fallback when OAuth app is not configured (Phase 0 only).
SELF_HOST_LOCAL_AUTH_EMAIL=
SELF_HOST_LOCAL_AUTH_PASSWORD=

# ---- Email (Phase 2: org invitations) -----------------------------------------
# Leave empty to skip invite emails and share invite links manually instead.
LOOPS_EMAIL_API_KEY=

# ---- Images / registry ---------------------------------------------------------
# DEFAULT: build locally from the patched source via ./build.sh (recommended;
# the built image includes the patched backend + remote-web frontend).
REMOTE_IMAGE=vibe-kanban-team-remote
IMAGE_TAG=local
ELECTRIC_TAG=1.3.3

# To use a prebuilt registry image instead of building, point these at it, e.g.:
#   REMOTE_IMAGE=ghcr.io/iamriajul/vibe-kanban-team-remote
#   IMAGE_TAG=0.1.44-20260617110518
# Override the source path for ./build.sh if your layout differs:
#   VK_DIR=../vibe-kanban

# ---- Issue-ingestion API (optional; docker compose --profile ingest) ----------
# Secret API key callers must send as `X-API-Key` (generate: openssl rand -hex 32)
INGEST_API_KEY=
# Service-account credentials (self-host local auth). This email MUST be a member
# of the team org that owns INGEST_PROJECT_ID. See ingest/README.md setup.
INGEST_SVC_EMAIL=issue-bot@rokomari.com
INGEST_SVC_PASSWORD=
# Target project UUID where issues are created.
INGEST_PROJECT_ID=
# Team org UUID — only needed to resolve `assignee` emails on POST.
INGEST_ORG_ID=
# Default status: by name substring (default "todo"), or pin an exact status UUID.
INGEST_STATUS_NAME=todo
INGEST_STATUS_ID=
# Base URL used to build issue links in the response (defaults to https://PUBLIC_DOMAIN).
INGEST_PUBLIC_URL=
# Agent-centric requirement drafts persistence file.
INGEST_REQUIREMENTS_FILE=/data/requirements-drafts.json
# Max request size in KB for ingest endpoints (supports large markdown requirement payloads).
INGEST_MAX_BODY_KB=2048
# Max child tasks auto-published per approved requirement epic.
INGEST_MAX_CHILD_TASKS=12

# ---- Optional R2 attachment storage (private bucket supported) ----------------
# Enable these to let remote issue attachment APIs generate short-lived signed URLs.
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REVIEW_ENDPOINT=
R2_REVIEW_BUCKET=
R2_REGION=auto
# Signed URL lifetime in seconds (default 300 = 5 minutes)
R2_PRESIGN_EXPIRY_SECS=300
# Max direct source upload body accepted by ingest (MB)
INGEST_UPLOAD_MAX_MB=20
# Optional auto-push from approved requirement drafts into memory service.
INGEST_MEMORY_URL=http://memory:8091
# Defaults to MEMORY_API_KEY in compose if left empty.
INGEST_MEMORY_API_KEY=

# ---- Organization memory profile (optional; docker compose --profile memory) ---
# Dedicated memory database (pgvector) credentials.
MEMORY_DB_PASSWORD=memory-change-me
# API key for /memory/* REST endpoints (generate: openssl rand -hex 32)
MEMORY_API_KEY=
# Service account for reading live VK data (defaults may be wired from SELF_HOST_LOCAL_AUTH_* in compose).
MEMORY_SVC_EMAIL=
MEMORY_SVC_PASSWORD=
# Default org scope used by ingest endpoints when org_id is omitted.
MEMORY_DEFAULT_ORG_ID=
# Embeddings provider config (default self-hosted ollama).
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://embedder:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768
EMBED_API_KEY=
EMBED_BATCH=32
# Comma-separated curated docs to ingest from MEMORY_DOC_ROOT.
MEMORY_DOC_INCLUDE=HANDOFF.md,GO_LIVE.md,SYSTEM_DESIGN.md,EXECUTION_PLAN.md,DEPLOYMENT_README.md,DEVELOPER_ONBOARDING.md,REQUIREMENTS_AND_PLAN.md
