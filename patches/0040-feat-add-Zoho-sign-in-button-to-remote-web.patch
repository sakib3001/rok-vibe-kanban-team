From bc0a208d930bb288a3065add439be353e765fee2 Mon Sep 17 00:00:00 2001
From: Rokomari <dev@rokomari.com>
Date: Thu, 18 Jun 2026 17:20:38 +0600
Subject: [PATCH] feat: add Zoho sign-in button to remote-web LoginPage and
 InvitationPage

---
 packages/remote-web/src/pages/InvitationPage.tsx |  9 ++++++++-
 packages/remote-web/src/pages/LoginPage.tsx      | 13 ++++++++++++-
 packages/remote-web/src/shared/lib/api.ts        |  2 +-
 3 files changed, 21 insertions(+), 3 deletions(-)

diff --git a/packages/remote-web/src/pages/InvitationPage.tsx b/packages/remote-web/src/pages/InvitationPage.tsx
index ae9b23f1c..0f1c85588 100644
--- a/packages/remote-web/src/pages/InvitationPage.tsx
+++ b/packages/remote-web/src/pages/InvitationPage.tsx
@@ -147,6 +147,13 @@ export default function InvitationPage() {
                 disabled={pendingProvider !== null}
                 loading={pendingProvider === "google"}
               />
+              <OAuthButton
+                provider="zoho"
+                label="Continue with Zoho"
+                onClick={() => void handleOAuthLogin("zoho")}
+                disabled={pendingProvider !== null}
+                loading={pendingProvider === "zoho"}
+              />
             </div>
           </section>
         </div>
@@ -177,7 +184,7 @@ function OAuthButton({
       disabled={disabled || loading}
     >
       {loading
-        ? `Opening ${provider === "github" ? "GitHub" : "Google"}...`
+        ? `Opening ${provider === "github" ? "GitHub" : provider === "google" ? "Google" : "Zoho"}...`
         : label}
     </button>
   );
diff --git a/packages/remote-web/src/pages/LoginPage.tsx b/packages/remote-web/src/pages/LoginPage.tsx
index 9446e0ed0..df90a3709 100644
--- a/packages/remote-web/src/pages/LoginPage.tsx
+++ b/packages/remote-web/src/pages/LoginPage.tsx
@@ -173,6 +173,17 @@ export default function LoginPage() {
                     loading={pending === "google"}
                   />
                 )}
+              {!isAuthMethodsError &&
+                hasOAuthProviders &&
+                oauthProviders.includes("zoho") && (
+                  <OAuthButton
+                    provider="zoho"
+                    label="Continue with Zoho"
+                    onClick={() => void handleLogin("zoho")}
+                    disabled={pending !== null}
+                    loading={pending === "zoho"}
+                  />
+                )}
             </div>
           </section>
 
@@ -215,7 +226,7 @@ function OAuthButton({
       disabled={disabled || loading}
     >
       {loading
-        ? `Opening ${provider === "github" ? "GitHub" : "Google"}...`
+        ? `Opening ${provider === "github" ? "GitHub" : provider === "google" ? "Google" : "Zoho"}...`
         : label}
     </button>
   );
diff --git a/packages/remote-web/src/shared/lib/api.ts b/packages/remote-web/src/shared/lib/api.ts
index feebf0cb4..f8910a66c 100644
--- a/packages/remote-web/src/shared/lib/api.ts
+++ b/packages/remote-web/src/shared/lib/api.ts
@@ -5,7 +5,7 @@ import type { ListOrganizationsResponse } from "shared/types";
 
 const API_BASE = import.meta.env.VITE_API_BASE_URL || "";
 
-export type OAuthProvider = "github" | "google";
+export type OAuthProvider = "github" | "google" | "zoho";
 
 export type AuthMethodsResponse = {
   local_auth_enabled: boolean;
-- 
2.43.0

