+            "step_index": 2,
+            "source": "MODEL",
+            "type": "PLANNER_RESPONSE",
+            "status": "DONE",
+            "created_at": "2026-06-14T00:01:01Z",
+            "content": "new answer"
+        }))
+        .unwrap();
+        state.handle_step(current_turn, &msg_store);
+
