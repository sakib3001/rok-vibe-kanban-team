+            .iter()
+            .filter(|entry| matches!(entry.entry_type, NormalizedEntryType::AssistantMessage))
+            .map(|entry| entry.content.clone())
+            .collect::<Vec<_>>();
+        assert_eq!(assistant_messages, vec!["new answer"]);
+    }
 }
