+pub struct ZohoOAuthProvider {
+    client: Client,
+    client_id: String,
+    client_secret: SecretString,
+    /// Base accounts URL (e.g. `https://accounts.zoho.com`).
+    accounts_url: String,
+}
+
+impl ZohoOAuthProvider {
+    pub fn new(
+        client_id: String,
+        client_secret: SecretString,
+        accounts_url: Option<String>,
+    ) -> Result<Self> {
+        let client = Client::builder().user_agent(USER_AGENT).build()?;
+        let accounts_url = accounts_url
+            .unwrap_or_else(|| "https://accounts.zoho.com".to_string())
+            .trim_end_matches('/')
+            .to_string();
+        Ok(Self {
+            client,
+            client_id,
+            client_secret,
+            accounts_url,
+        })
+    }
+
+    fn auth_endpoint(&self) -> String {
+        format!("{}/oauth/v2/auth", self.accounts_url)
+    }
+
+    fn token_endpoint(&self) -> String {
+        format!("{}/oauth/v2/token", self.accounts_url)
+    }
+
+    fn userinfo_endpoint(&self) -> String {
+        format!("{}/oauth/user/info", self.accounts_url)
+    }
+
+    async fn try_refresh_access_token(
+        &self,
+        refresh_token: &str,
+    ) -> Result<ProviderTokenDetails, TokenValidationError> {
+        let response = match self
+            .client
+            .post(&self.token_endpoint())
+            .form(&[
+                ("client_id", self.client_id.as_str()),
+                ("client_secret", self.client_secret.expose_secret()),
+                ("refresh_token", refresh_token),
+                ("grant_type", "refresh_token"),
+            ])
+            .send()
+            .await
+        {
+            Ok(resp) => resp,
+            Err(err) => {
+                return Err(TokenValidationError::temporary(format!(
+                    "zoho refresh request failed: {err}"
+                )));
+            }
+        };
+
+        match response.status() {
+            reqwest::StatusCode::OK => {
+                #[derive(Debug, Deserialize)]
+                struct RefreshResponse {
+                    access_token: String,
+                    expires_in: i64,
+                }
+
+                let refresh_data: RefreshResponse = response
+                    .json()
+                    .await
+                    .map_err(|err| TokenValidationError::temporary(format!("{err}")))?;
+                let expires_at = chrono::Utc::now().timestamp() + refresh_data.expires_in;
+
+                Ok(ProviderTokenDetails {
+                    provider: self.name().to_string(),
+                    access_token: refresh_data.access_token,
+                    // Zoho does not rotate refresh tokens on refresh
+                    refresh_token: Some(refresh_token.to_string()),
+                    expires_at: Some(expires_at),
+                })
+            }
+            reqwest::StatusCode::BAD_REQUEST => Err(TokenValidationError::InvalidOrRevoked),
+            status if status.is_server_error() => Err(TokenValidationError::temporary(format!(
+                "zoho token refresh server error: {status}"
+            ))),
+            status => Err(TokenValidationError::temporary(format!(
+                "unexpected zoho token refresh status: {status}"
+            ))),
+        }
+    }
+
+    async fn refresh_token(
+        &self,
+        refresh_token: &str,
+        max_retries: u32,
+    ) -> Result<ProviderTokenDetails, TokenValidationError> {
+        let mut attempt = 0;
+        loop {
+            attempt += 1;
+
+            match self.try_refresh_access_token(refresh_token).await {
+                Ok(new_token_details) => return Ok(new_token_details),
+                Err(TokenValidationError::InvalidOrRevoked) => {
+                    return Err(TokenValidationError::InvalidOrRevoked);
+                }
+                Err(TokenValidationError::Temporary(err)) => {
+                    if attempt >= max_retries {
+                        return Err(TokenValidationError::Temporary(err));
+                    }
+                    tokio::time::sleep(tokio::time::Duration::from_secs(RETRY_INTERVAL_SECONDS))
+                        .await;
+                }
+            }
+        }
+    }
+}
+
+#[derive(Debug, Deserialize)]
+#[serde(untagged)]
+enum ZohoTokenResponse {
+    Success {
+        access_token: String,
+        token_type: String,
+        #[serde(default)]
+        scope: Option<String>,
+        expires_in: Option<i64>,
+        refresh_token: Option<String>,
+    },
+    Error {
+        error: String,
+    },
+}
+
+#[derive(Debug, Deserialize)]
+struct ZohoUserInfo {
+    #[serde(rename = "ZUID")]
+    zuid: i64,
+    #[serde(rename = "First_Name")]
+    first_name: Option<String>,
+    #[serde(rename = "Last_Name")]
+    last_name: Option<String>,
+    #[serde(rename = "Display_Name")]
+    display_name: Option<String>,
+    #[serde(rename = "Email")]
+    email: Option<String>,
+}
+
+#[async_trait]
+impl AuthorizationProvider for ZohoOAuthProvider {
+    fn name(&self) -> &'static str {
+        "zoho"
+    }
+
+    fn scopes(&self) -> &[&str] {
+        &["openid", "email", "profile"]
+    }
+
+    fn authorize_url(&self, state: &str, redirect_uri: &str) -> Result<Url> {
+        let mut url = Url::parse(&self.auth_endpoint())?;
+        {
+            let mut qp = url.query_pairs_mut();
+            qp.append_pair("client_id", &self.client_id);
+            qp.append_pair("redirect_uri", redirect_uri);
+            qp.append_pair("response_type", "code");
+            qp.append_pair("scope", &self.scopes().join(" "));
+            qp.append_pair("state", state);
+            qp.append_pair("access_type", "offline");
+            qp.append_pair("prompt", "consent");
+        }
+        Ok(url)
+    }
+
+    async fn exchange_code(&self, code: &str, redirect_uri: &str) -> Result<AuthorizationGrant> {
+        let response = self
+            .client
+            .post(&self.token_endpoint())
+            .form(&[
+                ("client_id", self.client_id.as_str()),
+                ("client_secret", self.client_secret.expose_secret()),
+                ("code", code),
+                ("grant_type", "authorization_code"),
+                ("redirect_uri", redirect_uri),
+            ])
+            .send()
+            .await?;
+
+        let status = response.status();
+        let body = response.text().await?;
+
+        if !status.is_success() {
+            anyhow::bail!("zoho token exchange failed (HTTP {status}): {body}");
+        }
+
+        match serde_json::from_str::<ZohoTokenResponse>(&body)? {
+            ZohoTokenResponse::Success {
+                access_token,
+                token_type,
+                scope,
+                expires_in,
+                refresh_token,
+            } => {
+                let scopes = scope
+                    .unwrap_or_default()
+                    .split_whitespace()
+                    .filter_map(|value| {
+                        let trimmed = value.trim();
+                        (!trimmed.is_empty()).then_some(trimmed.to_string())
+                    })
+                    .collect();
+
+                Ok(AuthorizationGrant {
+                    access_token: SecretString::new(access_token.into()),
+                    token_type,
+                    scopes,
+                    refresh_token: refresh_token.map(|v| SecretString::new(v.into())),
+                    expires_in: expires_in.map(Duration::seconds),
+                    id_token: None,
+                })
+            }
+            ZohoTokenResponse::Error { error } => {
+                anyhow::bail!("zoho token exchange failed: {error}")
+            }
+        }
+    }
+
+    async fn fetch_user(&self, access_token: &SecretString) -> Result<ProviderUser> {
+        let response = self
+            .client
+            .get(&self.userinfo_endpoint())
+            .header("Authorization", format!("Zoho-oauthtoken {}", access_token.expose_secret()))
+            .send()
+            .await?;
+
+        let status = response.status();
+        let body = response.text().await?;
+
+        if !status.is_success() {
+            anyhow::bail!("zoho userinfo failed (HTTP {status}): {body}");
+        }
+
+        let profile: ZohoUserInfo = serde_json::from_str(&body)?;
+
+        let login = profile.email.clone();
+        let name = profile
+            .display_name
+            .or_else(|| match (&profile.first_name, &profile.last_name) {
+                (Some(first), Some(last)) => Some(format!("{first} {last}")),
+                (Some(first), None) => Some(first.clone()),
+                (None, Some(last)) => Some(last.clone()),
+                (None, None) => None,
+            });
+
+        Ok(ProviderUser {
+            id: profile.zuid.to_string(),
+            login,
+            email: profile.email,
+            name,
+            avatar_url: None,
+        })
+    }
+
+    async fn validate_token(
+        &self,
+        token_details: &ProviderTokenDetails,
+        max_retries: u32,
+    ) -> Result<Option<ProviderTokenDetails>, TokenValidationError> {
+        let mut attempt = 0;
+        let access_token = SecretString::new(token_details.access_token.clone().into_boxed_str());
