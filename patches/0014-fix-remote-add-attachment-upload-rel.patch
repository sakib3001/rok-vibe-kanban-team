@@ -56,6 +56,19 @@ pub enum R2Error {
     Storage(String),
 }
 
+fn format_error_chain<E: StdError>(err: &E) -> String {
+    let mut message = err.to_string();
+    let mut source = err.source();
+
+    while let Some(cause) = source {
+        message.push_str(": ");
+        message.push_str(&cause.to_string());
+        source = cause.source();
+    }
+
+    message
+}
